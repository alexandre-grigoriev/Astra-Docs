# ─────────────────────────────────────────────────────────────────────────────
# Stage 1 — install & compile native addons
# (bcrypt and better-sqlite3 both need build-essential + python3)
# ─────────────────────────────────────────────────────────────────────────────
FROM node:22-bookworm-slim AS deps

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    python3 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY backend/package*.json ./
RUN npm ci --omit=dev

# ─────────────────────────────────────────────────────────────────────────────
# Stage 2 — lean runtime image
# ─────────────────────────────────────────────────────────────────────────────
FROM node:22-bookworm-slim

WORKDIR /app

# Copy compiled node_modules from the build stage
COPY --from=deps /app/node_modules ./node_modules

# Copy application source
COPY backend/ ./

# /data is the external mount point for users.db and uploads/
RUN mkdir -p /data/uploads

EXPOSE 3001

HEALTHCHECK --interval=15s --timeout=5s --start-period=10s --retries=3 \
  CMD node -e "fetch('http://localhost:3001/health').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"

CMD ["node", "server.js"]
