# docker/.env  — docker-compose variables
# Copy this file to docker/.env and fill in the values.
# This file controls the compose build and the host port.
# It is NOT the backend runtime config — that lives in docker/data/backend.env.

# Port exposed on the host (default: 80)
HTTP_PORT=80

# Gemini API key — embedded in the frontend bundle at build time
# (the frontend calls Gemini directly for the chat interface)
VITE_GEMINI_API_KEY=AIzaSy...
